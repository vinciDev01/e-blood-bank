# Copiez ce fichier en `.env` à la racine du projet et renseignez vos valeurs.
# Le fichier `.env` est ignoré par git : n'y commitez jamais de secrets.

# SMTP (envoi d'e-mails)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=ton.email@gmail.com
EMAIL_HOST_PASSWORD=mot_de_passe_application_gmail
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Adresse e-mail de l'administrateur
ADMIN_EMAIL=admin@example.com

# Clé Google Maps (activer Geocoding API + Maps JavaScript API)
GOOGLE_MAPS_API_KEY=ta_cle_google_maps

# Vérification OTP au login. True en production ; False en test/dev pour un login direct.
OTP_ENABLED=False
